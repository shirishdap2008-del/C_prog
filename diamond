#include <stdio.h>
#include <stdlib.h>

int main()
{
    int n=5;
    for(int i=0;i<=n;i++)
{
        for(int j=0;j<n-i;j++)
    {
        printf("  ");
    }
    for(int k=0;k<=2*i;k++)
    {
        printf("* ");
    }
     printf("\n");
}
for(int i=n-1;i>1;i--)
{
        for(int j=1;j<=n-i;j++)
    {
        printf("  ");
    }
    for(int k=1;k<=2*i;k++)
    {
        printf("* ");
    }
     printf("\n");
}

    return 0;
}
