#include<stdio.h>
struct student
{
char name[50];
int rollno;
float marks;
};
    int main()
{
int b;
printf("enter no.of students:\n");
scanf("%d",&b);
struct student a;
for(int i=1;i<=b;i++)
{
printf("enter student name:");
scanf("\n");
scanf("%[^\n]",&a.name);
printf("enter student roll.no:\n");
scanf("%d",&a.rollno);
printf("enter student mark:\n");
scanf("%f",&a.marks);
}
for(int i=1;i<=b;i++)
{
printf("%s %d %.2f",a.name,a.rollno,a.marks);
}
return 0;
}



