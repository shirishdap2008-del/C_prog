#include <stdio.h>
#include <stdlib.h>

int main()
{
   int n=5;
   for(int i=0;i<=n;i++)
   {
       for(int j=0;j<=i;j++)
       {
           printf("* ");
       }
       for(int s=0;s<2*(n-i+1);s++)
       {
           printf("  ");
       }

       for(int k=0;k<=i;k++)
       {
           printf("* ");
       }
       printf("\n");
   }
   for(int i=0;i<=2*6;i++)
   {
    printf("* ");
   }
   printf("\n");
   for(int i=n;i>=0;i--)
   {
       for(int j=0;j<=i;j++)
       {
           printf("* ");
       }
       for(int s=0;s<2*(n-i+1);s++)
       {
           printf("  ");
       }

       for(int k=0;k<=i;k++)
       {
           printf("* ");
       }
       printf("\n");
   }
    return 0;
}
